# Financial API Keys
# Copy this file to .env and fill in your actual API keys

# Alpha Vantage API Key (required for Alpha Vantage data source)
# Get your free key at: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Finnhub API Key (required for Finnhub data source)
# Get your free key at: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Yahoo Finance API Key (optional - uses public endpoint by default)
# Required for higher rate limits
YAHOO_API_KEY=your_yahoo_api_key_here
